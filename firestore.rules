rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- helpers -----
    function signedIn() {
      return request.auth != null;
    }

    function bookingDoc(bookingId) {
      return get(/databases/$(database)/documents/bookings/$(bookingId));
    }

    function isBookingParticipant(bookingId) {
      let b = bookingDoc(bookingId).data;
      return signedIn() && (
        b.customerId == request.auth.uid ||
        b.driverId == request.auth.uid
      );
    }

    // ----- users: own profile only (signup + FCM token merge) -----
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    // ----- bookings -----
    match /bookings/{bookingId} {
      allow read: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        resource.data.status == 'pending'
      );
      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        (resource.data.status == 'pending'
          && request.resource.data.driverId == request.auth.uid)
      );
      allow delete: if signedIn() && resource.data.customerId == request.auth.uid;

      // ----- chat under a booking -----
      match /messages/{messageId} {
        allow read: if signedIn()
          && exists(/databases/$(database)/documents/bookings/$(bookingId))
          && isBookingParticipant(bookingId);
        allow create: if signedIn()
          && exists(/databases/$(database)/documents/bookings/$(bookingId))
          && isBookingParticipant(bookingId)
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ----- luggage (per userId) -----
    match /luggage/{docId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ----- ratings (driver dashboard reads; tighten when you add writes) -----
    match /ratings/{ratingId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
