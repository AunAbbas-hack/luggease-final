rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function bookingDoc(bookingId) {
      return get(/databases/$(database)/documents/bookings/$(bookingId));
    }

    function isBookingParticipant(bookingId) {
      let b = bookingDoc(bookingId).data;
      return signedIn() && (
        b.customerId == request.auth.uid ||
        b.driverId == request.auth.uid
      );
    }

    // ----- Profile collections by role (customers / drivers / admins) -----
    function isOwnProfileDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /customers/{userId} {
      allow read: if isOwnProfileDoc(userId);
      allow create: if isOwnProfileDoc(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'customer';
      allow update: if isOwnProfileDoc(userId);
      allow delete: if isOwnProfileDoc(userId);
    }

    match /drivers/{userId} {
      allow read: if isOwnProfileDoc(userId);
      allow create: if isOwnProfileDoc(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'driver';
      allow update: if isOwnProfileDoc(userId);
      allow delete: if isOwnProfileDoc(userId);
    }

    match /admins/{userId} {
      allow read: if isOwnProfileDoc(userId);
      allow create: if isOwnProfileDoc(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'admin';
      allow update: if isOwnProfileDoc(userId);
      allow delete: if isOwnProfileDoc(userId);
    }

    // Legacy `users` (existing accounts until migrated)
    match /users/{userId} {
      allow read: if isOwnProfileDoc(userId);
      allow create: if isOwnProfileDoc(userId)
        && request.resource.data.uid == userId;
      allow update: if isOwnProfileDoc(userId);
      allow delete: if isOwnProfileDoc(userId);
    }

    // ----- bookings -----
    match /bookings/{bookingId} {
      allow read: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        resource.data.status == 'pending'
      );
      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        (resource.data.status == 'pending'
          && request.resource.data.driverId == request.auth.uid)
      );
      allow delete: if signedIn() && resource.data.customerId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if signedIn()
          && exists(/databases/$(database)/documents/bookings/$(bookingId))
          && isBookingParticipant(bookingId);
        allow create: if signedIn()
          && exists(/databases/$(database)/documents/bookings/$(bookingId))
          && isBookingParticipant(bookingId)
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /luggage/{docId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /ratings/{ratingId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
